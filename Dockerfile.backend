FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY backend/package*.json ./

# Install dependencies
RUN npm ci --omit=dev

# Copy backend code
COPY backend/ ./

# Copy template files
COPY TEMPLATE/Scraped_Templates/ ./templates/

# Generate Prisma Client
RUN npx prisma generate

EXPOSE 3000

CMD ["node", "server.js"]
