generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WeddingConfig {
  id        String   @id @default(uuid())
  slug      String   @unique // e.g., "reiza-amanda"
  template  String?  // slug template terpilih, e.g., "tema-15-tanpa-foto"
  
  // JSONB block to cleanly store all dynamic forms (design colors, quotes, titles, livestream links)
  settings  Json?    
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

