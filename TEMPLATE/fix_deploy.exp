#!/usr/bin/expect -f
set timeout 120
spawn ssh -o StrictHostKeyChecking=no root@192.168.0.102 {cd /tmp/joyvite && git stash && git pull && sed -i 's|TEMPLATES_DIR: "/app/templates"|TEMPLATES_DIR: "/app/templates/Scraped_Templates"|' docker-compose.yml && docker compose build --no-cache joyvite-backend && docker compose up -d --force-recreate joyvite-backend && sleep 8 && curl -s -o /dev/null -w "%{http_code}" http://localhost:3500/test}
expect "password:"
send "Alamatgue123\r"
expect eof
